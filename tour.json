    "imagen9": {
      "title": "pasillo",
      "type": "equirectangular",
      "panorama": "assets/panoramicaswebp/9.webp",
      "hotSpots": [
        {
        "pitch": -29.0,
        "yaw": -43.1,
        "type": "info",
        "text": "<div class='tarjeta-museo' style='width: 650px; padding: 20px;'> <div class='tarjeta-info' style='display: flex; gap: 30px;'> <div style='flex: 1;'> <h3 style='color: var(--color-primario-oscuro); border-bottom: 2px solid var(--color-secundario); display: inline-block; padding-bottom: 5px; margin-bottom: 10px;'>Maqueta de la zona excavada</h3> <p style='font-size: 0.95rem; line-height: 1.5; color: #444;'>Maqueta de Xochicalco donde se contemplan los edificios que hasta hoy se han explorado. Podemos apreciar las modificaciones hechas por los antiguos habitantes sobre el cerro para construir el asentamiento fortificado de la ciudad, es necesario destacar que los poderes políticos y religiosos encabezaban la urbe, habitando ahí los personajes más importantes.</p> </div> <div style='flex: 1; border-left: 1px solid #ccc; padding-left: 20px;'> <h3 style='color: var(--color-secundario); border-bottom: 2px solid var(--color-primario); display: inline-block; padding-bottom: 5px; margin-bottom: 10px;'>Model of the Excavated Area</h3> <p style='font-size: 0.95rem; line-height: 1.5; color: #444;'>Architectural model of Xochicalco showing the buildings explored to date. The ancient inhabitants massively modified the hills to build a fortified city. Such large-scale works were directed by the city's political and religious leaders, as notable characters usually lived in the city.</p> </div> </div> </div>"
        },
